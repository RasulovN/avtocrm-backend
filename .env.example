# ===== App =====
# NODE_ENV: development | production
NODE_ENV=development

# PORT — backend tinglaydigan TCP port (nginx shu portga proxy qiladi).
PORT=8000

# HOST — Fastify qaysi tarmoq interfeysiga bog'lanadi:
#   • production: 127.0.0.1  (faqat localhost; nginx reverse-proxy orqali kiriladi,
#                             public portda OCHIQ BO'LMASLIGI kerak — xavfsizroq).
#   • development: 0.0.0.0   (barcha interfeyslar; LAN'dan ham test qilish uchun).
# Bo'sh qoldirsangiz NODE_ENV bo'yicha avtomatik tanlanadi (yuqoridagi qoida).
# DEV uchun:
HOST=0.0.0.0
# PROD uchun:
# HOST=127.0.0.1

# ===== Security =====
# Django SECRET_KEY ekvivalenti — JWT imzolash uchun
SECRET_KEY=django-insecure-lx4q4xl5oz+-bz7!=9h^=p&)92jn@0f-+dl3k=#fy55v!197si

# Access token muddati (sekund) — Django: 1 kun
ACCESS_TOKEN_TTL=86400
# Refresh token muddati (sekund) — Django: 7 kun
REFRESH_TOKEN_TTL=604800

# ===== Database (PostgreSQL) =====
