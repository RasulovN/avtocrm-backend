{
  "name": "autocrm-backend-node",
  "version": "1.0.0",
  "description": "AutoCRM backend — Fastify + TypeScript + Prisma (PostgreSQL). Django REST backend'dan ko'chirilgan.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "predev": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "payme:test": "tsx src/scripts/payme-test.ts",
    "payme:fiscal-test": "tsx src/scripts/payme-fiscal-test.ts",
    "payme:reset": "tsx src/scripts/payme-reset-order.ts",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.1",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "bwip-js": "^4.5.1",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.1",
    "libphonenumber-js": "^1.11.20",
    "fastify-plugin": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.10.0",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.5",
    "@types/nodemailer": "^6.4.17",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
