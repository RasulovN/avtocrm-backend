// ============================================================
//  CONTRACT (suppliers, stock entries)
// ============================================================

model Supplier {
  id                Int      @id @default(autoincrement())
  companyId         Int      @map("company_id")
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name              String   @db.VarChar(255)
  nameUzCyrl        String?  @map("name_uz_cyrl") @db.VarChar(255)
  phoneNumber       String   @map("phone_number") @db.VarChar(20)
  description       String
  descriptionUzCyrl String?  @map("description_uz_cyrl")
  inn               String?  @db.VarChar(50)
  address           String
  addressUzCyrl     String?  @map("address_uz_cyrl")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  entries      StockEntry[]
  transactions SupplierTransaction[]

  @@unique([companyId, inn])
  @@index([companyId])
  @@index([phoneNumber])
  @@index([inn])
  @@map("supplier")
}

model StockEntry {
  id          Int      @id @default(autoincrement())
  companyId   Int      @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierId  Int      @map("supplier_id")
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  storeId     Int      @map("store_id")
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)
  totalAmount Decimal  @default(0) @map("total_amount") @db.Decimal(15, 2)
  cashAmount  Decimal  @default(0) @map("cash_amount") @db.Decimal(15, 2)
  cardAmount  Decimal  @default(0) @map("card_amount") @db.Decimal(15, 2)
  paidAmount  Decimal  @default(0) @map("paid_amount") @db.Decimal(15, 2)
  debtAmount  Decimal  @default(0) @map("debt_amount") @db.Decimal(15, 2)
  paymentType String   @default("cash") @map("payment_type") @db.VarChar(7) // cash/card/mixed
  createdById Int?     @map("created_by_id")
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items        StockEntryItem[]
  transactions SupplierTransaction[]

  @@index([companyId])
  @@map("stock_entry")
}

model StockEntryItem {
  id             Int        @id @default(autoincrement())
  entryId        Int        @map("entry_id")
  entry          StockEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  productId      Int        @map("product_id")
  product        Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity       Int
  purchasePrice  Decimal    @map("purchase_price") @db.Decimal(12, 2)
  sellingPrice   Decimal    @map("selling_price") @db.Decimal(12, 2)
  wholesalePrice Decimal    @default(0) @map("wholesale_price") @db.Decimal(12, 2)

  @@map("stock_entry_item")
}

model SupplierTransaction {
  id         Int         @id @default(autoincrement())
  companyId  Int         @map("company_id")
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierId Int         @map("supplier_id")
  supplier   Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  entryId    Int?        @map("entry_id")
  entry      StockEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
  amount     Decimal     @db.Decimal(15, 2)
  type       String      @db.VarChar(5) // in / pay
  note       String      @default("")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("supplier_transaction")
}

// ============================================================
//  INVENTORY
// ============================================================

model InventorySession {
  id            Int      @id @default(autoincrement())
  companyId     Int      @map("company_id")
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  storeId       Int      @map("store_id")
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  startedById   Int?     @map("started_by_id")
  startedBy     User?    @relation(fields: [startedById], references: [id], onDelete: SetNull)
  startedAt     DateTime @default(now()) @map("started_at")
  status        String   @default("active") @db.VarChar(20) // active/completed/cancelled
  snapshotTaken Boolean  @default(false) @map("snapshot_taken")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  snapshots   InventorySnapshot[]
  counts      InventoryCount[]
  movements   InventoryMovement[]
  adjustments InventoryAdjustment[]

  @@index([companyId])
  @@index([storeId, status])
  @@map("inventory_session")
}

model InventorySnapshot {
  id               Int              @id @default(autoincrement())
  sessionId        Int              @map("session_id")
  session          InventorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId        Int              @map("product_id")
  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId          Int              @map("store_id")
  store            Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  expectedQuantity Int              @map("expected_quantity")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@unique([sessionId, productId])
  @@index([sessionId, productId])
  @@map("inventory_snapshot")
}

model InventoryCount {
  id              Int              @id @default(autoincrement())
  sessionId       Int              @map("session_id")
  session         InventorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId       Int              @map("product_id")
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  countedQuantity Int              @default(0) @map("counted_quantity")
  status          String           @default("p") @db.VarChar(10) // p/e/l/m
  isCheck         Boolean          @default(false) @map("is_check")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@unique([sessionId, productId])
  @@map("inventory_count")
}

model InventoryMovement {
  id        Int              @id @default(autoincrement())
  sessionId Int              @map("session_id")
  session   InventorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId Int              @map("product_id")
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  type      String           @db.VarChar(20) // s/to/r/ti/e
  refId     Int              @map("ref_id")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([sessionId, productId])
  @@map("inventory_movement")
}

model InventoryAdjustment {
  id         Int              @id @default(autoincrement())
  sessionId  Int              @map("session_id")
  session    InventorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  productId  Int              @map("product_id")
  product    Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  difference Int
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  @@index([sessionId])
  @@map("inventory_adjustment")
}

model LowStockItem {
  id              Int       @id @default(autoincrement())
  companyId       Int       @map("company_id")
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  storeId         Int       @map("store_id")
  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId       Int       @map("product_id")
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  currentQuantity Int       @map("current_quantity")
  minStock        Int       @map("min_stock")
  actionType      String    @map("action_type") @db.VarChar(10) // purchase/transfer
  status          String    @default("open") @db.VarChar(10) // open/resolved
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([status, actionType])
  @@index([storeId, status])
  @@index([productId, status])
  @@index([status, createdAt])
  @@map("low_stock_item")
}

// ============================================================
//  SALES
// ============================================================

model Sale {
  id             Int       @id @default(autoincrement())
  companyId      Int       @map("company_id")
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  storeId        Int       @map("store_id")
  store          Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerId     Int?      @map("customer_id")
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  sellerId       Int       @map("seller_id")
  seller         User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  totalAmount    Decimal   @default(0) @map("total_amount") @db.Decimal(20, 2)
  paidAmount     Decimal   @default(0) @map("paid_amount") @db.Decimal(20, 2)
  status         String    @db.VarChar(10) // paid/partial/debt/r
  discountType   String?   @map("discount_type") @db.VarChar(10) // p/f
  discountValue  Decimal   @default(0) @map("discount_value") @db.Decimal(20, 2)
  discountAmount Decimal   @default(0) @map("discount_amount") @db.Decimal(20, 2)
  createdAt      DateTime  @default(now()) @map("created_at")

  items       SaleItem[]
  payments    Payment[]
  returns     SaleReturn[]
  debtRecords CustomerDebt[]

  @@index([companyId])
  @@index([customerId])
  @@index([status])
  @@map("sales_sale")
}

model SaleItem {
  id               Int      @id @default(autoincrement())
  saleId           Int      @map("sale_id")
  sale             Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId        Int      @map("product_id")
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity         Int
  purchasePrice    Decimal? @map("purchase_price") @db.Decimal(20, 2)
  unitPrice        Decimal  @map("unit_price") @db.Decimal(20, 2)
  totalPrice       Decimal  @map("total_price") @db.Decimal(20, 2)
  returnedQuantity Int      @default(0) @map("returned_quantity")

  returnItems SaleReturnItem[]

  @@map("sales_saleitem")
}

model Payment {
  id         Int       @id @default(autoincrement())
  companyId  Int       @map("company_id")
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  saleId     Int?      @map("sale_id")
  sale       Sale?     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  customerId Int?      @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount     Decimal   @db.Decimal(20, 2)
  type       String    @db.VarChar(5) // cash/card
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("sales_payment")
}

model SaleReturn {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  saleId      Int       @map("sale_id")
  sale        Sale      @relation(fields: [saleId], references: [id], onDelete: Restrict)
  storeId     Int       @map("store_id")
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customerId  Int?      @map("customer_id")
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  sellerId    Int       @map("seller_id")
  seller      User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  totalRefund Decimal   @default(0) @map("total_refund") @db.Decimal(20, 2)
  comment     String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  items SaleReturnItem[]

  @@index([companyId])
  @@map("sale_return")
}

model SaleReturnItem {
  id           Int        @id @default(autoincrement())
  saleReturnId Int        @map("sale_return_id")
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  saleItemId   Int        @map("sale_item_id")
  saleItem     SaleItem   @relation(fields: [saleItemId], references: [id], onDelete: Restrict)
  productId    Int        @map("product_id")
  product      Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity     Int
  unitPrice    Decimal    @map("unit_price") @db.Decimal(20, 2)
  totalPrice   Decimal    @map("total_price") @db.Decimal(20, 2)

  @@map("sale_return_item")
}

// ============================================================
//  DEBTS
// ============================================================

model CustomerDebt {
  id         Int       @id @default(autoincrement())
  companyId  Int       @map("company_id")
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId Int       @map("customer_id")
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  saleId     Int?      @map("sale_id")
  sale       Sale?     @relation(fields: [saleId], references: [id], onDelete: SetNull)
  amount     Decimal   @db.Decimal(20, 2)
  type       String    @db.VarChar(2) // i/d
  dueDate    DateTime? @map("due_date") @db.Date
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("debts_customerdebt")
}

// ============================================================
//  TRANSFER
// ============================================================

model StockTransfer {
  id           Int       @id @default(autoincrement())
  companyId    Int       @map("company_id")
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromStoreId  Int       @map("from_store_id")
  fromStore    Store     @relation("OutgoingTransfers", fields: [fromStoreId], references: [id], onDelete: Cascade)
  toStoreId    Int       @map("to_store_id")
  toStore      Store     @relation("IncomingTransfers", fields: [toStoreId], references: [id], onDelete: Cascade)
  status       String    @default("p") @db.VarChar(1) // p/a/r
  createdById  Int?      @map("created_by_id")
  createdBy    User?     @relation("CreatedTransfers", fields: [createdById], references: [id], onDelete: SetNull)
  approvedById Int?      @map("approved_by_id")
  approvedBy   User?     @relation("ApprovedTransfers", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  items         StockTransferItem[]
  notifications Notification[]

  @@index([companyId])
  @@map("stock_transfer")
}

model StockTransferItem {
  id              Int           @id @default(autoincrement())
  stockTransferId Int           @map("stock_transfer_id")
  stockTransfer   StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  productId       Int           @map("product_id")
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity        Int
  purchasePrice   Decimal       @map("purchase_price") @db.Decimal(12, 2)
  sellingPrice    Decimal       @map("selling_price") @db.Decimal(12, 2)
  createdAt       DateTime      @default(now()) @map("created_at")

  @@map("stock_transfer_item")
}

model Notification {
  id             Int            @id @default(autoincrement())
  // Platforma (super admin) broadcast'lari uchun null bo'lishi mumkin
  companyId      Int?           @map("company_id")
  company        Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId         Int            @map("user_id")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           String         @db.VarChar(20) // tc/ta/tr/lp/lt/announcement
  title          String         @db.VarChar(255)
  message        String
  link           String?        @db.VarChar(255) // bosilganda yo'naltirish (ixtiyoriy)
  isRead         Boolean        @default(false) @map("is_read")
  // Hayot sikli: active -> archived -> (avtomatik o'chiriladi)
  status         String         @default("active") @db.VarChar(10)
  archivedAt     DateTime?      @map("archived_at")
  transferId     Int?           @map("transfer_id")
  transfer       StockTransfer? @relation(fields: [transferId], references: [id], onDelete: Cascade)
  announcementId Int?           @map("announcement_id")
  // SetNull: admin broadcast'ni o'chirsa, qabul qiluvchilarning bildirishnomasi DB'da QOLADI.
  announcement   Announcement?  @relation(fields: [announcementId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([userId, isRead])
  @@index([userId, status])
  @@index([status, createdAt])
  @@index([status, archivedAt])
  @@map("notification")
}

// Super admin tomonidan yuborilgan ommaviy bildirishnoma (broadcast) yozuvi.
// Har bir qabul qiluvchi uchun alohida Notification yozuvi yaratiladi (o'qilgan holati uchun).
model Announcement {
  id             Int      @id @default(autoincrement())
  createdById    Int?     @map("created_by_id")
  createdBy      User?    @relation("AnnouncementsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  title          String   @db.VarChar(255)
  message        String
  link           String?  @db.VarChar(255)
  // all | mobile | company_users | company_admins | company
  audience       String   @db.VarChar(20)
  // audience = company bo'lsa, aniq kompaniya
  companyId      Int?     @map("company_id")
  company        Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recipientCount Int      @default(0) @map("recipient_count")
  createdAt      DateTime @default(now()) @map("created_at")

  notifications Notification[]

  @@index([audience])
  @@map("announcement")
}

// Foydalanuvchi harakatlari auditi (asosiy amallar: login/logout, create/update/delete)
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId Int?     @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // login | logout | create | update | delete
  action    String   @db.VarChar(20)
  // qaysi modul/obyekt: product, sale, transfer, stock_entry, user, price, category ...
  entity    String?  @db.VarChar(50)
  entityId  Int?     @map("entity_id")
  // qisqacha izoh (masalan "Mahsulot 'X' yaratildi") va qo'shimcha ma'lumot
  summary   String?  @db.VarChar(255)
  meta      Json?
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  // Arxivlangan vaqti. null = faol log (kompaniya/foydalanuvchi panelida ko'rinadi).
  // To'ldirilgan = arxivda (faqat super admin panelida ko'rinadi). 2 oydan keyin
  // avtomatik to'ldiriladi; arxivdan 3 oy o'tgach yozuv butunlay o'chiriladi.
  archivedAt DateTime? @map("archived_at")

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([entity])
  @@index([archivedAt])
  @@map("audit_log")
}

// ───────── Foydalanish statistikasi (kunlik rollup) ─────────
// Har bir (kompaniya, foydalanuvchi, kun) uchun bitta qator: so'rovlar,
// kirishlar va yozuv amallari soni. Super admin "Foydalanish tahlili" paneli
// shu jadvaldan o'qiydi — audit_log'ni har safar skan qilishdan ancha yengil.
// Yozuv: plugins/usage.ts xotirada yig'ib, davriy ravishda upsert qiladi.
model UsageDaily {
  id        Int     @id @default(autoincrement())
  companyId Int     @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    Int     @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Asia/Tashkent (UTC+5) bo'yicha kun
  date      DateTime @db.Date
  // Barcha autentifikatsiyalangan so'rovlar (o'qish ham) — umumiy faollik o'lchovi
  requests  Int      @default(0)
  logins    Int      @default(0)
  // Yozuv amallari (create/update/delete)
  actions   Int      @default(0)

  @@unique([companyId, userId, date])
  @@index([date])
  @@index([userId, date])
  @@map("usage_daily")
}

// ───────── Landing: demo so'rovlar (zayavkalar) ─────────
model Lead {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(150)
  phone       String   @db.VarChar(50)
  email       String   @db.VarChar(150)
  company     String?  @db.VarChar(150)
  storesRange String?  @map("stores_range") @db.VarChar(50)
  message     String?
  source      String   @default("landing") @db.VarChar(50)
  status      String   @default("new") @db.VarChar(20) // new | approved | rejected | contacted | closed
  locale      String?  @db.VarChar(10)
  note        String? // admin ichki izohi
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("lead")
}

// ───────── Landing: tahrirlanadigan sozlamalar (key/value JSON) ─────────
model SiteSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(80)
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_setting")
}
