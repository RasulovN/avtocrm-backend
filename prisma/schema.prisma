// AutoCRM SaaS — Prisma schema (PostgreSQL)
// Multi-tenant: har bir CRM yozuvi `companyId` orqali tenant (Company)ga bog'langan.
// Platforma darajasi: Super admin -> Company -> Company users (RBAC rol/ruxsat).
// Tarjima (django-modeltranslation) maydonlari uchun `*UzCyrl` ustunlari saqlangan.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
//  SAAS PLATFORM — Company, RBAC, Subscription, Address
// ============================================================

model Company {
  id         Int     @id @default(autoincrement())
  name       String  @db.VarChar(255)
  nameUzCyrl String? @map("name_uz_cyrl") @db.VarChar(255)
  slug       String? @unique @db.VarChar(255)

  ownerId Int  @unique @map("owner_id")
  owner   User @relation("CompanyOwner", fields: [ownerId], references: [id])

  categoryId Int?             @map("category_id")
  category   CompanyCategory? @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  // Manzil (ierarxik) + xarita
  countryId  Int?      @map("country_id")
  country    Country?  @relation(fields: [countryId], references: [id], onDelete: SetNull)
  regionId   Int?      @map("region_id")
  region     Region?   @relation(fields: [regionId], references: [id], onDelete: SetNull)
  districtId Int?      @map("district_id")
  district   District? @relation(fields: [districtId], references: [id], onDelete: SetNull)
  street     String?
  latitude   Decimal?  @db.Decimal(10, 7)
  longitude  Decimal?  @db.Decimal(10, 7)

  phoneNumber String? @map("phone_number") @db.VarChar(20)
  email       String? @db.VarChar(254)
  logo        String? @db.VarChar(255)
  // Boy aloqa ma'lumotlari (telefon, email, manzil, xarita koordinatasi, ijtimoiy tarmoqlar).
  // Landing/site-settings bilan bir xil ContactInfo shaklida JSON saqlanadi.
  contact     Json?

  // onboarding -> active -> suspended
  status   String  @default("onboarding") @db.VarChar(20)
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // SaaS bog'lanishlar
  users                User[]                @relation("CompanyMembers")
  roles                Role[]
  subscriptions        Subscription[]
  supportConversations SupportConversation[]

  // CRM bog'lanishlar (tenant ma'lumotlari)
  stores                  Store[]
  customers               Customer[]
  suppliers               Supplier[]
  categories              Category[]
  brands                  Brand[]
  products                Product[]
  productLocations        ProductLocation[]
  productUnitMeasurements ProductUnitMeasurement[]
  productBatches          ProductBatch[]
  stockEntries            StockEntry[]
  supplierTransactions    SupplierTransaction[]
  inventorySessions       InventorySession[]
  lowStockItems           LowStockItem[]
  sales                   Sale[]
  saleReturns             SaleReturn[]
  payments                Payment[]
  customerDebts           CustomerDebt[]
  stockTransfers          StockTransfer[]
  notifications           Notification[]
  announcements           Announcement[]
  auditLogs               AuditLog[]
  usageDaily              UsageDaily[]

  @@index([categoryId])
  @@index([status])
  @@index([countryId, regionId, districtId])
  @@map("company")
}

model CompanyCategory {
  id                Int      @id @default(autoincrement())
  name              String   @unique @db.VarChar(150)
  nameRu            String?  @map("name_ru")
  nameEn            String?  @map("name_en")
  nameUzCyrl        String?  @map("name_uz_cyrl") @db.VarChar(150)
  slug              String   @unique @db.VarChar(160)
  description       String?
  descriptionRu     String?  @map("description_ru")
  descriptionEn     String?  @map("description_en")
  descriptionUzCyrl String?  @map("description_uz_cyrl")
  icon              String?  @db.VarChar(255)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  companies Company[]

  @@map("company_category")
}

// ---- Manzil ierarxiyasi (super admin to'ldiradi) ----

model Country {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(150)
  nameUzCyrl String?  @map("name_uz_cyrl") @db.VarChar(150)
  nameRu     String?  @map("name_ru") @db.VarChar(150)
  nameEn     String?  @map("name_en") @db.VarChar(150)
  code       String?  @db.VarChar(5)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  regions   Region[]
  companies Company[]

  @@map("country")
}

model Region {
  id         Int      @id @default(autoincrement())
  countryId  Int      @map("country_id")
  country    Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  name       String   @db.VarChar(150)
  nameUzCyrl String?  @map("name_uz_cyrl") @db.VarChar(150)
  nameRu     String?  @map("name_ru") @db.VarChar(150)
  nameEn     String?  @map("name_en") @db.VarChar(150)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  districts District[]
  companies Company[]

  @@index([countryId])
  @@map("region")
}

model District {
  id         Int      @id @default(autoincrement())
  regionId   Int      @map("region_id")
  region     Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  name       String   @db.VarChar(150)
  nameUzCyrl String?  @map("name_uz_cyrl") @db.VarChar(150)
  nameRu     String?  @map("name_ru") @db.VarChar(150)
  nameEn     String?  @map("name_en") @db.VarChar(150)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  companies Company[]

  @@index([regionId])
  @@map("district")
}

// ---- RBAC ----

model Permission {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(100) // masalan: "products.view", "roles.manage"
  label     String   @db.VarChar(150)
  module    String   @db.VarChar(50) // menu/modul guruhi
  // platform = super admin tomoni, company = kompaniya tomoni, both = ikkalasi
  scope     String   @default("company") @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@index([module])
  @@index([scope])
  @@map("permission")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?
  // platform = super admin rollari (companyId null), company = kompaniya rollari
  scope       String   @db.VarChar(10)
  companyId   Int?     @map("company_id")
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // tizim roli (Owner, Super Admin) — o'chirib bo'lmaydi
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       User[]

  @@unique([companyId, name])
  @@index([scope])
  @@map("role")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int        @map("role_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId Int        @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permission")
}

// ---- Obuna / Tariflar ----

model Plan {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(100)
  nameRu            String?  @map("name_ru")
  nameEn            String?  @map("name_en")
  nameUzCyrl        String?  @map("name_uz_cyrl")
  description       String?
  descriptionRu     String?  @map("description_ru")
  descriptionEn     String?  @map("description_en")
  descriptionUzCyrl String?  @map("description_uz_cyrl")
  price             Decimal  @db.Decimal(15, 2)
  durationDays      Int      @map("duration_days") // obuna muddati (kun)
  // Uzoq muddatga oldindan to'lovda chegirma foizi (0-90). 1 oy uchun chegirma yo'q.
  // Summa = price * oylar * (1 - chegirma/100).
  discountM3        Int      @default(0) @map("discount_m3")  // 3 oy uchun chegirma %
  discountM6        Int      @default(0) @map("discount_m6")  // 6 oy uchun chegirma %
  discountM12       Int      @default(0) @map("discount_m12") // 12 oy uchun chegirma %
  features          Json? // tarif imkoniyatlari
  maxStores         Int?     @map("max_stores")
  maxUsers          Int?     @map("max_users")
  isActive          Boolean  @default(true) @map("is_active")
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plan")
}

model Subscription {
  id        Int       @id @default(autoincrement())
  companyId Int       @map("company_id")
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId    Int       @map("plan_id")
  plan      Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  // pending -> active -> expired / cancelled
  status    String    @default("pending") @db.VarChar(20)
  amount    Decimal   @db.Decimal(15, 2)
  // Oldindan to'langan oylar soni (1 | 3 | 6 | 12). Faollashtirishda muddat =
  // plan.durationDays * periodMonths kun. Bepul tarif uchun har doim 1.
  periodMonths Int    @default(1) @map("period_months")
  startAt   DateTime? @map("start_at")
  endAt     DateTime? @map("end_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  transactions PaymeTransaction[]

  @@index([companyId, status])
  @@map("subscription")
}

model PaymeTransaction {
  id             Int           @id @default(autoincrement())
  paycomId       String        @unique @map("paycom_id") @db.VarChar(50) // Payme tranzaksiya id
  subscriptionId Int?          @map("subscription_id")
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  amount         Decimal       @db.Decimal(15, 2) // tiyin
  // 1 = yaratilgan, 2 = bajarilgan, -1 = bekor (perform oldidan), -2 = bekor (perform keyin)
  state          Int           @default(1)
  reason         Int?
  createTime     BigInt        @default(0) @map("create_time")
  performTime    BigInt        @default(0) @map("perform_time")
  cancelTime     BigInt        @default(0) @map("cancel_time")
  account        Json?
  // Soliq (OFD) fiskal chek havolasi — https://ofd.soliq.uz/epi?t=..&r=..&c=..&s=..
  // Payme `SetFiscalData` metodi orqali AVTOMATIK yuboradi (qr_code_url shu yerga
  // ko'chiriladi). Super admin qo'lda ham biriktirishi mumkin (zaxira).
  fiscalUrl      String?       @map("fiscal_url")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  fiscalReceipts PaymeFiscalReceipt[]

  @@map("payme_transaction")
}

// Payme `SetFiscalData` (Merchant API) orqali kelgan fiskal (Soliq/OFD) chek.
// Payme fiskallashtirish tugagach webhookka chaqiradi va fiscal_data'ni yuboradi.
// Har bir tranzaksiya uchun 2 tur bo'lishi mumkin: PERFORM (to'lov) va CANCEL (bekor).
model PaymeFiscalReceipt {
  id             Int      @id @default(autoincrement())
  // params.id — Payme bazasidagi chek id (Merchant API'da tranzaksiya paycomId'si).
  paymeReceiptId String   @map("payme_receipt_id") @db.VarChar(50)
  type           String   @db.VarChar(10) // PERFORM | CANCEL

  transactionId  Int?              @map("transaction_id")
  transaction    PaymeTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  subscriptionId Int?              @map("subscription_id")

  // fiscal_data (rasmiy maydonlar)
  receiptId  String? @map("receipt_id") @db.VarChar(50) // Virtual Fiskal Modul tartib raqami
  terminalId String? @map("terminal_id") @db.VarChar(50) // VFM raqami
  fiscalSign String? @map("fiscal_sign") @db.VarChar(60) // fiskal belgi
  qrCodeUrl  String? @map("qr_code_url") // fiskal chek URL (QR ichidagi manzil)
  statusCode Int?    @map("status_code")
  message    String?
  fiscalDate String? @map("fiscal_date") @db.VarChar(50) // OFD ro'yxatga olingan sana
  raw        Json? // to'liq fiscal_data (audit uchun)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([paymeReceiptId, type])
  @@index([subscriptionId])
  @@index([transactionId])
  @@map("payme_fiscal_receipt")
}

// ---- Support chat (yordam) ----
// Har bir foydalanuvchi uchun bitta suhbat (Telegram uslubidagi chat).
model SupportConversation {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId       Int?      @map("company_id")
  company         Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  status          String    @default("open") @db.VarChar(20) // open | closed
  lastMessageAt   DateTime? @map("last_message_at")
  lastMessageText String?   @map("last_message_text")
  // Foydalanuvchi ko'rmagan (agentdan kelgan) xabarlar soni
  userUnread      Int       @default(0) @map("user_unread")
  // Agent (super admin) ko'rmagan (foydalanuvchidan kelgan) xabarlar soni
  agentUnread     Int       @default(0) @map("agent_unread")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  messages SupportMessage[]

  @@index([companyId])
  @@index([status, lastMessageAt])
  @@map("support_conversation")
}

model SupportMessage {
  id             Int                 @id @default(autoincrement())
  conversationId Int                 @map("conversation_id")
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       Int                 @map("sender_id")
  sender         User                @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderRole     String              @map("sender_role") @db.VarChar(10) // user | agent
  body           String?             @db.Text
  // Biriktirilgan fayllar: [{ url, name, type, size }]
  attachments    Json?
  isRead         Boolean             @default(false) @map("is_read")
  createdAt      DateTime            @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("support_message")
}

model EmailVerification {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("email_verification")
}

// ============================================================
//  USERS
// ============================================================

model User {
  id          Int     @id @default(autoincrement())
  fullName    String? @map("full_name") @db.VarChar(128)
  phoneNumber String? @unique @map("phone_number") @db.VarChar(20)
  email       String? @unique @db.VarChar(254)
  password    String  @db.VarChar(255)

  isActive        Boolean   @default(true) @map("is_active")
  isStaff         Boolean   @default(false) @map("is_staff")
  isSuperuser     Boolean   @default(false) @map("is_superuser")
  isEmailVerified Boolean   @default(false) @map("is_email_verified")
  lastLogin       DateTime? @map("last_login")

  // Foydalanuvchi qaysi platformadan ro'yxatdan o'tgan/kiradi: web | mobile
  // Notification segmentlash uchun ("mobil userlar")
  platform String @default("web") @map("platform") @db.VarChar(10)

  // Tenant a'zoligi (super admin uchun null)
  companyId Int?     @map("company_id")
  company   Company? @relation("CompanyMembers", fields: [companyId], references: [id], onDelete: SetNull)
  roleId    Int?     @map("role_id")
  role      Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ownedCompany         Company?            @relation("CompanyOwner")
  emailVerifications   EmailVerification[]
  storeLinks           StoreUser[]         @relation("UserStoreLinks")
  history              UserHistory[]
  stockEntries         StockEntry[]
  inventorySessions    InventorySession[]
  sales                Sale[]
  saleReturns          SaleReturn[]
  createdTransfers     StockTransfer[]     @relation("CreatedTransfers")
  approvedTransfers    StockTransfer[]     @relation("ApprovedTransfers")
  notifications        Notification[]
  announcementsCreated Announcement[]      @relation("AnnouncementsCreated")
  auditLogs            AuditLog[]
  supportConversation  SupportConversation?
  supportMessages      SupportMessage[]
  usageDaily           UsageDaily[]

  @@index([phoneNumber])
  @@index([email])
  @@index([companyId])
  @@index([platform])
  @@map("users_user")
}

model Customer {
  id          Int      @id @default(autoincrement())
  companyId   Int      @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fullName    String   @map("full_name") @db.VarChar(100)
  phoneNumber String   @map("phone_number") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sales       Sale[]
  payments    Payment[]
  debts       CustomerDebt[]
  saleReturns SaleReturn[]

  @@index([companyId])
  @@map("users_customer")
}

model UserHistory {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   @db.VarChar(10) // li=Login, lo=Logout
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("users_userhistory")
}

// ============================================================
//  STORE
// ============================================================

model Store {
  id            Int     @id @default(autoincrement())
  companyId     Int     @map("company_id")
  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String  @db.VarChar(255)
  nameUzCyrl    String? @map("name_uz_cyrl") @db.VarChar(255)
  phoneNumber   String  @map("phone_number") @db.VarChar(20)
  address       String
  addressUzCyrl String? @map("address_uz_cyrl")
  type          String  @db.VarChar(10) // b=Base, s=Store

  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userLinks          StoreUser[]         @relation("StoreUserLinks")
  productBatches     ProductBatch[]
  stockEntries       StockEntry[]
  inventorySessions  InventorySession[]
  inventorySnapshots InventorySnapshot[]
  sales              Sale[]
  saleReturns        SaleReturn[]
  outgoingTransfers  StockTransfer[]     @relation("OutgoingTransfers")
  incomingTransfers  StockTransfer[]     @relation("IncomingTransfers")
  lowStockItems      LowStockItem[]

  @@index([companyId])
  @@index([phoneNumber])
  @@index([type])
  @@index([isActive])
  @@map("store")
}

model StoreUser {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation("UserStoreLinks", fields: [userId], references: [id], onDelete: Cascade)
  storeId   Int      @map("store_id")
  store     Store    @relation("StoreUserLinks", fields: [storeId], references: [id], onDelete: Cascade)
  role      String   @db.VarChar(20) // m=Manager, s=Seller
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, storeId])
  @@index([userId])
  @@index([storeId])
  @@map("store_user")
}

// ============================================================
//  PRODUCTS
// ============================================================

model Category {
  id                Int      @id @default(autoincrement())
  companyId         Int      @map("company_id")
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  slug              String   @db.VarChar(100)
  name              String   @db.VarChar(100)
  nameRu            String?  @map("name_ru")
  nameEn            String?  @map("name_en")
  nameUzCyrl        String?  @map("name_uz_cyrl") @db.VarChar(100)
  description       String
  descriptionRu     String?  @map("description_ru")
  descriptionEn     String?  @map("description_en")
  descriptionUzCyrl String?  @map("description_uz_cyrl")
  image             String?  @db.VarChar(255)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  products Product[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@map("category")
}

model Brand {
  id         Int     @id @default(autoincrement())
  companyId  Int     @map("company_id")
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String  @db.VarChar(100)
  nameUzCyrl String? @map("name_uz_cyrl") @db.VarChar(100)

  products Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("brand")
}

model Product {
  id                Int                     @id @default(autoincrement())
  companyId         Int                     @map("company_id")
  company           Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId        Int?                    @map("category_id")
  category          Category?               @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brandId           Int?                    @map("brand_id")
  brand             Brand?                  @relation(fields: [brandId], references: [id], onDelete: Restrict)
  name              String                  @db.VarChar(100)
  nameUzCyrl        String?                 @map("name_uz_cyrl") @db.VarChar(100)
  unitMeasurementId Int?                    @map("unit_measurement_id")
  unitMeasurement   ProductUnitMeasurement? @relation(fields: [unitMeasurementId], references: [id], onDelete: Restrict)
  description       String                  @default("")
  descriptionUzCyrl String?                 @map("description_uz_cyrl")

  sku        String? @db.VarChar(64)
  barcode    String? @db.VarChar(13)
  shtrixCode String? @map("shtrix_code") @db.VarChar(255)

  status   String @default("a") @db.VarChar(20) // a=Active, i=Inactive, d=Draft
  minStock Int    @default(0) @map("min_stock")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  images               ProductImage[]
  batches              ProductBatch[]
  stockEntryItems      StockEntryItem[]
  inventorySnapshots   InventorySnapshot[]
  inventoryCounts      InventoryCount[]
  inventoryMovements   InventoryMovement[]
  inventoryAdjustments InventoryAdjustment[]
  lowStockItems        LowStockItem[]
  saleItems            SaleItem[]
  saleReturnItems      SaleReturnItem[]
  transferItems        StockTransferItem[]

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId])
  @@index([sku])
  @@index([barcode])
  @@index([name])
  @@map("product")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  image     String  @db.VarChar(255)

  @@map("product_image")
}

model ProductBatch {
